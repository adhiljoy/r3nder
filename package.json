{
  "name": "r3nder",
  "version": "1.0.0",
  "description": "Premium Discord Bot with Web Dashboard",
  "main": "src/index.ts",
  "scripts": {
    "start": "ts-node -r tsconfig-paths/register src/index.ts",
    "dev": "concurrently \"npm run dev:bot\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:bot": "ts-node -r tsconfig-paths/register src/index.ts",
    "dev:server": "cd dashboard/server && ts-node -r tsconfig-paths/register src/server.ts",
    "dev:client": "cd dashboard/client && npm run dev",
    "build:client": "cd dashboard/client && npm run build",
    "tsc:check": "npx tsc --noEmit && cd dashboard/server && npx tsc --noEmit && cd ../client && npx tsc --noEmit"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "axios": "^1.6.7",
    "discord.js": "^14.14.1",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.3.0",
    "form-data": "^4.0.5",
    "mongodb": "^7.1.1",
    "mongoose": "^8.2.1",
    "openai": "^4.28.4",
    "play-dl": "^1.9.7",
    "ytdl-core": "^4.11.5"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.25",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.2"
  }
}
