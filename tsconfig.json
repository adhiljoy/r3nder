{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "paths": {
      "@client/*": ["src/client/*"],
      "@services/*": ["src/services/*"],
      "@database/*": ["src/database/shared/*"],
      "@config/*": ["src/config/*"],
      "@utils/*": ["src/utils/*"],
      "@events/*": ["src/events/*"],
      "@appTypes/*": ["src/types/*"],
      "@routes/*": ["src/routes/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ESNext"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
