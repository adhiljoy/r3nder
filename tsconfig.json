{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./",
    "baseUrl": "./",
    "paths": {
      "@client/*": ["src/client/*"],
      "@services/*": ["src/services/*"],
      "@database/*": ["dashboard/shared/models/*"],
      "@config/*": ["src/config/*"],
      "@utils/*": ["src/utils/*"],
      "@events/*": ["src/events/*"],
      "@appTypes/*": ["src/types/*"]
    },
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "lib": ["ESNext"]
  },
  "include": ["src/**/*", "dashboard/shared/**/*"],
  "exclude": ["node_modules"]
}
