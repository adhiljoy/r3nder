# 🚀 R3NDER - Discord Bot & Dashboard Configuration
# NOTE: If your password contains special characters (e.g., @, #, !, :), 
# you MUST manually URL-encode them in the MONGO_URI.
# Example: pass@word -> pass%40word

# DISCORD CONFIGURATION
TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
CLIENT_SECRET=your_client_secret_here
CALLBACK_URL=http://localhost:3001/auth/callback
GUILD_ID=your_test_guild_id_here
ADMIN_IDS=your_discord_id_here,another_id

# DATABASE CONFIGURATION
# 1. Go to MongoDB Atlas: https://cloud.mongodb.com/
# 2. Clusters -> Connect -> Drivers -> Node.js
# 3. Copy the string and replace <db_password> with your password
MONGO_URI=mongodb+srv://username:<db_password>@cluster.mongodb.net/r3nder

# API CONFIGURATION
OPENAI_API_KEY=your_openai_api_key_here
SESSION_SECRET=your_random_session_secret_here
PORT=3001

# ACRCloud (Music Recognition)
ACR_HOST=us-west-2.api.acrcloud.com
ACR_ACCESS_KEY=your_access_key
ACR_SECRET_KEY=your_secret_key
