# 🚀 R3NDER - Production SaaS Dashboard & Discord Autopilot
# 🌀 Mission: Enterprise-Grade Community Management

# 🔐 SECURITY VAULT: IDENTITY HANDSHAKE
TOKEN=your_high_fidelity_bot_token
CLIENT_ID=your_discord_application_id
CLIENT_SECRET=your_discord_application_secret
CALLBACK_URL=https://your-api.onrender.com/auth/callback
ADMIN_IDS=your_discord_id_here

# 🛰️ INFRASTRUCTURE: MONOLITHIC DATABASE
# Protocol: mongodb+srv:// (SRV Resolution forced via 8.8.8.8)
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/r3nder

# 🌀 SONIC FLUX: AI & UTILITY
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
SESSION_SECRET=your_saas_session_secret

# 🌍 GLOBAL GATEWAY: CLOUD SYNC
FRONTEND_URL=https://r3nder-x18m.vercel.app
VITE_API_URL=https://r3nder-api.onrender.com

# 🎵 MUSIC ENGINE: HIFI RECOGNITION (ACRCloud)
ACR_HOST=us-west-2.api.acrcloud.com
ACR_ACCESS_KEY=your_access_key
ACR_SECRET_KEY=your_secret_key
